# Required: your Feishu receiver id used by OpenClaw message send
# Example: ou_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FEISHU_TARGET=

# Optional: cache/state directory
STATE_DIR=.state

# Optional: push behavior
MAX_POSTS_PER_RUN=3
MAX_MEDIA=4
ENFORCE_RECENCY=1
MAX_POST_AGE_HOURS=24
ENABLE_AI_RELEVANCE_FILTER=1
ENABLE_THREAD_MERGE=1

# Optional: content generation
ENABLE_TRANSLATION=1
ENABLE_ANALYSIS=1
ENABLE_DEEP_MEDIA_ANALYSIS=0

# Optional: fetch fallback
ALLOW_JINA_FALLBACK=1

# Debug
DRY_RUN=0
